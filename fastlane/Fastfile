default_platform(:android)

platform :ios do
  desc "Upload signed ipa to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["APPSTORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APPSTORE_CONNECT_API_ISSUER_ID"],
      key_filepath: ENV["APPSTORE_CONNECT_API_KEY_FILE"],
      in_house: false,
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: ENV["IPA_PATH"] || "build/ios/ipa/pensine.ipa",
      skip_waiting_for_build_processing: true,
    )
  end
end

platform :mac do
  desc "Upload signed .pkg to App Store Connect (Mac App Store)"
  lane :mas do
    api_key = app_store_connect_api_key(
      key_id: ENV["APPSTORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APPSTORE_CONNECT_API_ISSUER_ID"],
      key_filepath: ENV["APPSTORE_CONNECT_API_KEY_FILE"],
      in_house: false,
    )

    # `upload_to_app_store` with skip_* flags behaves like `upload_to_testflight`
    # for macOS: takes a signed .pkg, pushes it to App Store Connect, does
    # not touch metadata or screenshots. Auto-release-after-approval is
    # configured on the App Store Connect side (see DEPLOYMENT.md), so
    # this lane's job ends at "build uploaded".
    upload_to_app_store(
      api_key: api_key,
      pkg: ENV["PKG_PATH"] || "build/macos/Build/Products/Release/pensine.pkg",
      platform: "osx",
      skip_metadata: true,
      skip_screenshots: true,
      skip_app_version_update: true,
      submit_for_review: false,
      force: true,
      precheck_include_in_app_purchases: false,
    )
  end
end

platform :android do
  desc "Build signed AAB and upload to Play Console internal track"
  lane :beta do
    build_number = (ENV["GITHUB_RUN_NUMBER"] || "1").to_i
    build_date = Time.now.utc.strftime("%Y-%m-%d %H:%M:%S UTC")

    sh("cd .. && flutter build appbundle --release --build-number=#{build_number} --dart-define=BUILD_DATE='#{build_date}'")

    upload_to_play_store(
      track: "internal",
      aab: "build/app/outputs/bundle/release/app-release.aab",
      json_key: ENV["PLAY_JSON_KEY_FILE"],
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      release_status: "draft",
    )
  end
end
